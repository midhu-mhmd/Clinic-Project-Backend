# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?appName=Cluster0

# Auth
JWT_SECRET=your_jwt_secret_here
GOOGLE_CLIENT_ID=your_google_client_id_here

# Email (SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Payments (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Cloud Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI Service (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Cross-Origin Resource Sharing (CORS)
# Comma-separated list of allowed origins (e.g. your production frontend URL)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Frontend redirection URL
CLIENT_URL=http://localhost:5173
